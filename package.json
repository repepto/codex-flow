{
  "name": "@repepto/codex-flow",
  "version": "0.2.5",
  "description": "CLI installer and doctor for the Codex Flow starter pack.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/repepto/codex-flow.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "bin": {
    "codex-flow": "bin/codex-flow.js"
  },
  "files": [
    "AGENTS.md",
    "README.md",
    ".codex/core/",
    "bin/",
    "lib/"
  ],
  "scripts": {
    "doctor": "node bin/codex-flow.js doctor",
    "pack:dry-run": "npm pack --dry-run",
    "test": "node --test",
    "check": "npm test && npm run doctor && npm run pack:dry-run"
  },
  "engines": {
    "node": ">=18"
  }
}
